PORT=3000
NODE_ENV=development
# Files directory (mount WebDAV/NFS/SMB here); must match root .env FILES_DIR
FILES_DIR=/mnt/hsf-kiosk-files

# Calendar URLs (configured in template.json with url_env field)
# Example: CALENDAR_HSF=https://example.com/calendar.ics
# CALENDAR_HSF=
# CALENDAR_EVENTS=

# Tickets API (configured in template.json with url_env/token_env)
# Example: TICKETS_API_URL=https://todo.hsfev.duckdns.org/api/v1/tickets
# TICKETS_API_URL=
# TICKETS_API_TOKEN=
